import pandas as pd 
import matplotlib.pyplot as plt
import seaborn as sns 

url = "https://raw.githubusercontent.com/mwaskom/seaborn-data/master/iris.csv"
df = pd.read_csv(url)

print("Distribuzione specie:")
print(df['specie'].value_counts())

print("\nMedie petali per specie:")
print(df.groupby('species')[['petal_length', 'petal_width']].mean())

sns.scatterplot(data=df, x='petal_length', y='petal_width', hue='species')
plt.title('Dimensioni petali per specie')
plt.show()

df['area_petalo'] = df['petal_length'] * df['petal_width']

sns.boxplot(data=df, x='species', y='area_petalo')
plt.title("Distribuzione dell'area del petalo per specie")
plt.show()
