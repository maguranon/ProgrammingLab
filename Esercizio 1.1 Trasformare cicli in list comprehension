#ESEMPIO 1
num_pari = []
for n in range(0, 100):
  if n % 2 == 0:
    num_pari.append(n)

num_pari2 = [n for n in range(0, 100) if n % 2 == 0]

print("Numeri pari con il ciclo for:", num_pari)
print("Numeri pari con la list comprehension:", num_pari2)

